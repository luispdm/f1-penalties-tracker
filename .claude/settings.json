{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo check:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo run:*)",
      "Bash(cargo bench:*)",
      "Bash(cargo doc:*)",
      "Bash(cargo tree:*)",
      "Bash(rustc --version)",
      "Bash(rustup show)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git add:*)",
      "Bash(git rm:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr checkout:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh issue close:*)",
      "Bash(gh project view:*)",
      "Bash(gh project item-list:*)",
      "Bash(gh project item-view:*)",
      "Bash(gh project item-edit:*)",
      "Bash(gh project field-list:*)",
      "Bash(gh api graphql:*)",
      "Bash(gh api repos/*/pulls/*/comments:*)",
      "Bash(gh api -X POST repos/*/pulls/*/comments/*/replies:*)",
      "Bash(gh api repos/*/pulls/*/reviews:*)",
      "Bash(gh api -X POST repos/*/pulls/*/reviews:*)",
      "Bash(gh api repos/*/issues/*/comments:*)",
      "Bash(gh api repos/*/issues/*:*)",
      "Bash(.claude/scripts/reviewer-app-token.sh)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push origin main:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git rebase:*)",
      "Bash(git reset --hard:*)",
      "Bash(git reset --soft:*)",
      "Bash(gh pr close:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(sudo:*)"
    ]
  }
}
